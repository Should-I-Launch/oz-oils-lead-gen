# =============================================================================
# Hypajump Template — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# For local Docker Compose development, most defaults work out of the box.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Postgres)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app
POSTGRES_HOST=db
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
DEBUG=false
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Routing (Traefik + sslip.io)
# Replace 168.110.206.157 with your machine's IP address
# -----------------------------------------------------------------------------
FRONTEND_HOST=hypajump.168.110.206.157.sslip.io
BACKEND_HOST=api-hypajump.168.110.206.157.sslip.io
FRONTEND_URL=https://hypajump.168.110.206.157.sslip.io
VITE_API_URL=https://api-hypajump.168.110.206.157.sslip.io

# -----------------------------------------------------------------------------
# Clerk Authentication (optional — set VITE_CLERK_ENABLED=true to activate)
# Get keys from https://dashboard.clerk.com
# -----------------------------------------------------------------------------
VITE_CLERK_ENABLED=false
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk route configuration
VITE_CLERK_SIGN_IN_URL=/sign-in
VITE_CLERK_SIGN_UP_URL=/sign-up
VITE_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/user
VITE_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/user

# -----------------------------------------------------------------------------
# Efferd Registry (optional — for prebuilt UI blocks)
# Keep token in frontend/.env.local for local dev
# -----------------------------------------------------------------------------
EFFERD_REGISTRY_TOKEN=
